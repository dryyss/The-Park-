# ============================================================
#  The Park — variables d'environnement (modèle)
#  Copier en .env (gitignored) et remplir. Aucun secret commité.
# ============================================================

# Base de données (PostgreSQL — Neon/Supabase UE de préférence, RGPD)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# URL publique de l'app (redirects Stripe, Auth0, liens e-mails).
# Dev local : localhost OK. Sur Vercel : URL réelle (ex. https://the-park.vercel.app).
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Auth0 (comptes, âge, consentement parental) ---
# Dashboard → Application → Settings :
#   Allowed Callback URLs : http://localhost:3000/auth/callback , https://<domaine>/auth/callback
#   Allowed Logout / Web Origins : mêmes origines sans /auth/callback
AUTH0_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Management API (sync rôles staff + lecture rôles à la connexion)
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_M2M_AUDIENCE=

# --- Auth0 Action Post-Login (Dashboard, aucun secret dans l'action) ---
# 1. Actions → Library → Build Custom → coller scripts/auth0/post-login-sync-roles.js
# 2. Actions → Flows → Login → glisser l'action après login
# 3. APIs → Settings → RBAC ON + « Add Roles in the Access Token »
# 4. pnpm auth0:setup — crée les rôles park_* et affiche la matrice
# 5. pnpm staff:seed — comptes staff démo (mot de passe : STAFF_DEMO_PASSWORD ou ThePark2026!)
STAFF_DEMO_PASSWORD=
# E-mails Owner bootstrap (accès /admin sans rôle Auth0 préalable) — séparés par des virgules
STAFF_OWNER_EMAILS=

# --- Stripe (boutique + portefeuille marketplace + Connect vendeurs + caution C2C) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Connect (retrait gains vendeur sur /portefeuille) :
#   Dashboard Stripe → Connect → activer Express accounts
#   Webhook endpoint : ajouter checkout.session.completed, account.updated,
#   payment_intent.amount_capturable_updated, payment_intent.canceled
#   Local : stripe listen --forward-to localhost:3000/api/webhooks/stripe

# --- Cron jobs internes (Vercel Cron ou scheduler externe) ---
# Vercel injecte CRON_SECRET automatiquement si crons définis dans vercel.json.
# Appel : GET ou POST /api/cron/maintenance avec Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Resend (e-mails transactionnels) ---
# Prod : vérifier un domaine sur resend.com → RESEND_FROM_EMAIL = noreply@ton-domaine.fr
# Test : pnpm test:resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Payload CMS v3 (catalogue — V2) ---
PAYLOAD_SECRET=

# --- Pusher (chat contextualisé / temps réel) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# --- Stockage objet (images admin, photos collection/messages, vidéos preuves C2C) ---
# Backend prioritaire : Cellar (Clever Cloud, compatible S3). Sinon Vercel Blob. Sinon disque local (dev).
#
# CELLAR (Clever Cloud) : HOST / KEY_ID / KEY_SECRET sont injectés automatiquement
# quand l'addon Cellar est lié à l'app (clever service link-addon).
# Il ne reste qu'à définir le nom du bucket (public-read) — voir docs/DEPLOIEMENT-PROD.md.
# CELLAR_ADDON_HOST=cellar-c2.services.clever-cloud.com
# CELLAR_ADDON_KEY_ID=
# CELLAR_ADDON_KEY_SECRET=
CELLAR_BUCKET=the-park-media
# CELLAR_REGION=us-east-1
#
# VERCEL BLOB (si déploiement Vercel) : Dashboard → Storage → Blob → token injecté auto.
# BLOB_READ_WRITE_TOKEN=
# PRISMA_LOG_QUERIES=1

# Web Push (notifications navigateur). Générer une paire : `npx web-push generate-vapid-keys`
# La clé publique doit être dupliquée en NEXT_PUBLIC_ (exposée au client pour l'abonnement).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:contact@thepark.app
