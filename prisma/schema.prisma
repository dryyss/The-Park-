// ============================================================================
//  THE PARK — Schéma de données (v0)
//  Trading Card Game · collection, marketplace, échanges, boutique, escrow.
//
//  Périmètre : CDC-THEPARK-2026-002 (V1 enrichie) + extension "paiement réel"
//  validée le 15/06/2026 (envoi sécurisé / caution Stripe / enchères /
//  boutique officielle / litiges) — à acter par avenant au contrat.
//
//  ⚠ v0 à affiner avec le MD de cadrage à venir.
//  ⚠ Catalogue (Card/Season/Rarity/VersionType) : modélisé ici comme source de
//     vérité. Si Payload CMS v3 gère ces tables, on arbitrera l'appartenance à
//     l'intégration du Module 5 (import catalogue).
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
//  ENUMS
// ============================================================================

/// Rôle de base du compte (membre vs staff). Le détail du staff est dans AdminRole.
enum UserRole {
  MEMBER
  MODERATOR
  ADMIN
}

/// Sous-rôles admin (CDC §6) : permissions masquées côté serveur.
/// OWNER = accès total ; les autres rôles ne voient que leurs modules.
enum AdminRole {
  OWNER
  MODERATOR
  CATALOG_MANAGER
  SHOP_MANAGER
  SUPPORT
}

/// Cycle de vie d'un compte (modération + RGPD).
enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  BANNED
  DELETED
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

/// Neuve, Excellent, Très bon, Bon, Moyen, Abîmée (CDC Module 3)
enum CardCondition {
  MINT
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
  DAMAGED
}

/// Langue d'impression de la carte (≠ langue d'interface).
enum Language {
  FR
  EN
  JP
  DE
  US
}

enum ListingType {
  SELL
  TRADE
  SELL_OR_TRADE
  WANT
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  SOLD
  CANCELLED
  EXPIRED
}

enum ShippingMode {
  STANDARD
  SECURED
}

/// Transporteurs supportés par l'agrégateur de suivi (CDC couche C2C).
enum Carrier {
  LAPOSTE
  COLISSIMO
  CHRONOPOST
  MONDIAL_RELAY
  OTHER
}

enum ProductType {
  BOOSTER
  DISPLAY
  STARTER_DECK
  PROMO_PACK
  MERCH
  LIMITED_EDITION
}

enum StockMovementType {
  RESTOCK    // Réassort (entrée)
  SALE       // Sortie automatique après vente
  RETURN     // Retour client (rentrée)
  ADJUSTMENT // Ajustement manuel admin
  LOSS       // Perte / casse
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  CLOSED
  SOLD
  CANCELLED
}

/// Machine à états d'un échange entre membres (double validation + envoi sécurisé).
/// Aligné sur "The Park - Machine à États" (§5 plan de sécurisation).
enum ExchangeStatus {
  PROPOSED
  ACCEPTED
  AWAITING_SHIPMENT
  SHIPPED
  DELIVERED_WINDOW // livré · fenêtre 72h en cours
  DELIVERED
  COMPLETED
  GUARANTEE_SUSPENDED // ré-autorisation refusée (J+5)
  NOT_SHIPPED_CANCELLED // non expédié dans les délais (J+3)
  DISPUTED
  CANCELLED
}

/// Machine à états d'une vente marketplace (paiement + envoi sécurisé).
enum SaleStatus {
  PENDING_PAYMENT
  PAID
  AWAITING_SHIPMENT
  SHIPPED
  DELIVERED_WINDOW // livré · fenêtre 72h en cours
  DELIVERED
  COMPLETED
  GUARANTEE_SUSPENDED
  NOT_SHIPPED_CANCELLED
  DISPUTED
  CANCELLED
  REFUNDED
}

enum ShipmentType {
  SALE
  EXCHANGE
  ORDER
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
  LOST
}

/// Preuves vidéo horodatées de l'envoi sécurisé + déballage filmé.
enum ProofKind {
  PRESENTATION
  ENVELOPE
  CLOSURE_ADDRESS
  DROP_RECEIPT
  UNBOXING
}

enum PaymentKind {
  CAUTION
  PURCHASE
  SECURED_FEE
  STORE_ORDER
  AUCTION_PAYMENT
  WALLET_TOP_UP
}

/// Calque sur les statuts d'un PaymentIntent Stripe (pré-autorisation / capture).
enum PaymentStatus {
  REQUIRES_PAYMENT
  AUTHORIZED
  CAPTURED
  PARTIALLY_CAPTURED
  RELEASED
  REFUNDED
  CANCELLED
  FAILED
}

enum DisputeType {
  SALE
  EXCHANGE
  ORDER
  AUCTION
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_EVIDENCE
  RESOLVED
  CLOSED
}

enum DisputeVerdict {
  FAVOR_CLAIMANT
  FAVOR_RESPONDENT
  SPLIT
}

enum CaptureDecision {
  FULL
  PARTIAL
  NONE
  REFUND
}

enum ReviewSource {
  SALE
  EXCHANGE
}

enum ConversationContext {
  EXCHANGE
  SALE
  AUCTION
  DISPUTE
}

enum ReportTargetType {
  USER
  LISTING
  MESSAGE
  REVIEW
  SHOP
  AUCTION
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum NotificationType {
  EXCHANGE_PROPOSED
  EXCHANGE_ACCEPTED
  EXCHANGE_COMPLETED
  SALE_CREATED
  PAYMENT_AUTHORIZED
  SHIPMENT_SHIPPED
  SHIPMENT_DELIVERED
  GUARANTEE_EXPIRING
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  OFFER_RECEIVED
  AUCTION_OUTBID
  AUCTION_WON
  AUCTION_ENDED
  REVIEW_RECEIVED
  BADGE_UNLOCKED
  LISTING_SOLD
  LISTING_IN_CART
  LISTING_EXPIRING
  WISHLIST_LISTING
  ORDER_UPDATE
  MESSAGE_RECEIVED
}

enum MarketplaceCheckoutStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
}

enum MarketplaceInvoiceRecipient {
  BUYER
  SELLER
}

// ============================================================================
//  UTILISATEURS, PROFIL, RÉPUTATION  (Module 1, 8, 9)
// ============================================================================

model User {
  id          String     @id @default(cuid())
  auth0Id     String?    @unique
  email       String     @unique
  displayName String
  /// Pseudo personnalisé dans l'app (ne pas écraser par Auth0 à la connexion).
  displayNameCustom Boolean @default(false)
  slug        String     @unique
  avatarUrl   String?
  bio         String?
  role        UserRole   @default(MEMBER)
  /// Sous-rôle staff (null = membre simple). Vérifié côté serveur.
  staffRole   AdminRole?
  language    Language   @default(FR)

  // Cycle de vie du compte (modération + RGPD)
  status         AccountStatus @default(PENDING_VERIFICATION)
  suspendedUntil DateTime?
  bannedAt       DateTime?
  lastLoginAt    DateTime?
  deletedAt      DateTime? // soft-delete RGPD

  // Protection des mineurs (CDC §5.2)
  birthDate       DateTime?
  parentalConsent ParentalConsent?

  // Visibilité (CDC Module 1)
  profileVisibility    Visibility @default(PUBLIC)
  collectionVisibility Visibility @default(PUBLIC)
  shopVisibility       Visibility @default(PUBLIC)

  // Paiement / conformité
  kycStatus              KycStatus @default(NONE)
  stripeCustomerId       String? // achats boutique (côté payeur)
  stripeConnectAccountId String? // vendeur C2C (Stripe Connect)
  connectChargesEnabled  Boolean   @default(false)
  connectPayoutsEnabled  Boolean   @default(false)

  // Réputation dénormalisée (calculée à partir de Review)
  ratingAvg        Float @default(0)
  reviewCount      Int   @default(0)
  /// Score de fiabilité C2C (P2) : module le niveau de preuves exigé, pas le taux de caution.
  reliabilityScore Int   @default(0)

  notificationPrefs Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  collectionItems CollectionItem[]
  wishlistItems   WishlistItem[]
  cardLikes       CardLike[]
  listings        Listing[]
  cartItems       CartItem[]
  marketplaceCartItems MarketplaceCartItem[]
  marketplaceCheckouts MarketplaceCheckout[]
  marketplaceInvoices  MarketplaceInvoice[]
  orders          Order[]

  auctionsSelling Auction[] @relation("AuctionSeller")
  auctionsWon     Auction[] @relation("AuctionWinner")
  bids            Bid[]

  exchangesInitiated Exchange[] @relation("ExchangeInitiator")
  exchangesReceived  Exchange[] @relation("ExchangeRecipient")

  salesAsBuyer  Sale[] @relation("SaleBuyer")
  salesAsSeller Sale[] @relation("SaleSeller")

  shipmentsSent     Shipment[] @relation("ShipmentShipper")
  shipmentsReceived Shipment[] @relation("ShipmentRecipient")

  paymentsAsPayer Payment[] @relation("PaymentPayer")
  paymentsAsPayee Payment[] @relation("PaymentPayee")

  disputesAsClaimant   Dispute[]           @relation("DisputeClaimant")
  disputesAsRespondent Dispute[]           @relation("DisputeRespondent")
  disputesOpened       Dispute[]           @relation("DisputeOpener")
  disputeResolutions   DisputeResolution[]
  disputeEvidence      DisputeEvidence[]

  reviewsAuthored Review[]    @relation("ReviewAuthor")
  reviewsReceived Review[]    @relation("ReviewTarget")
  badges          UserBadge[]

  conversations ConversationParticipant[]
  messages      Message[]
  notifications Notification[]

  addresses         Address[]
  transactionEvents TransactionEvent[]

  reportsMade       Report[]
  moderationActions ModerationAction[]
  connectionLogs    ConnectionLog[]

  walletAccount WalletAccount?

  @@index([role])
  @@index([staffRole])
  @@index([status])
}

/// Consentement parental vérifiable pour les moins de 15 ans (RGPD art. 8).
model ParentalConsent {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String    @unique
  guardianName  String?
  guardianEmail String
  method        String? // ex: email vérifié, justificatif…
  token         String?   @unique
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
}

/// Carnet d'adresses (livraison / facturation) — commandes boutique + envois C2C.
model Address {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  label     String? // ex: "Domicile", "Bureau"
  fullName  String
  line1     String
  line2     String?
  zip       String
  city      String
  country   String  @default("FR")
  phone     String?
  isDefault Boolean @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================================================
//  CATALOGUE  (Module 2, 5) — éventuellement géré par Payload CMS v3
// ============================================================================

model Season {
  id          String    @id @default(cuid())
  code        String    @unique // ex: "S01"
  name        String // ex: "Moteur Forgé"
  releaseDate DateTime?
  sortOrder   Int       @default(0)
  cards       Card[]
  wishlists   WishlistItem[]
  createdAt   DateTime  @default(now())
}

model Rarity {
  id        String  @id @default(cuid())
  code      String  @unique // c, r, u, l, g, unique, promotional, special, collaboration, signed
  label     String // Commune, Rare Holo…
  symbol    String? // ◆ ◈ ✦ ❀ ✸ ✪
  color     String? // hex
  sortOrder Int     @default(0)
  cards     Card[]
}

/// Type de version (paramétrable par l'admin) : Standard, Unique, Promotionnelle, Carte spéciale, Collaboration, Signé…
model VersionType {
  id        String        @id @default(cuid())
  code      String        @unique
  label     String
  isFoil    Boolean       @default(false)
  sortOrder Int           @default(0)
  variants  CardVariant[]
}

model Card {
  id          String  @id @default(cuid())
  season      Season  @relation(fields: [seasonId], references: [id])
  seasonId    String
  number      Int // numéro dans la saison
  name        String
  slug        String  @unique
  rarity      Rarity  @relation(fields: [rarityId], references: [id])
  rarityId    String
  imageUrl    String?
  quoteValue  Decimal @default(0) @db.Decimal(10, 2) // cote indicative (€)
  powerCh     Int? // puissance (ch)
  weightKg    Int? // poids (kg)
  country     String? // code pays, extensible (JP, US, DE…)
  description String?
  isUnique    Boolean @default(false)

  variants  CardVariant[]
  wishlists WishlistItem[]
  likes     CardLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seasonId, number])
  @@index([rarityId])
}

/// Déclinaison concrète et collectionnable d'une carte (carte × version × langue).
model CardVariant {
  id            String      @id @default(cuid())
  card          Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId        String
  versionType   VersionType @relation(fields: [versionTypeId], references: [id])
  versionTypeId String
  language      Language    @default(FR)
  editionLabel  String? // ex: "1ère édition"
  imageUrl      String? // override visuel (reverse/alt art) sinon Card.imageUrl

  collectionItems CollectionItem[]
  listings        Listing[]
  auctions        Auction[]
  exchangeItems   ExchangeItem[]
  wishlistItems   WishlistItem[]

  @@unique([cardId, versionTypeId, language])
}

// ============================================================================
//  COLLECTION & WISHLIST  (Module 3, 4)
// ============================================================================

model CollectionItem {
  id               String        @id @default(cuid())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  variant          CardVariant   @relation(fields: [variantId], references: [id])
  variantId        String
  condition        CardCondition @default(EXCELLENT)
  quantity         Int           @default(1)
  /// Quantité engagée dans une annonce/échange actif (vérification de possession).
  reservedQuantity Int           @default(0)
  forTrade         Boolean       @default(false)
  forSale          Boolean       @default(false)
  note             String?
  /// Édition de l'exemplaire possédé (ex. « 1ère édition », « Illimitée »). Null = illimitée.
  editionLabel     String?

  // Gradation optionnelle (PSA, PCA…)
  isGraded     Boolean @default(false)
  gradeCompany String?
  gradeScore   Float?

  /// Exemplaire signé (autographe artiste / créateur).
  isSigned        Boolean @default(false)
  signatureAuthor String?

  photos CollectionItemPhoto[]

  acquiredAt DateTime @default(now())

  @@unique([userId, variantId, condition])
  @@index([userId])
}

/// Photo réelle d'un exemplaire possédé (upload collectionneur, visible publiquement).
model CollectionItemPhoto {
  id               String         @id @default(cuid())
  collectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  collectionItemId String
  /// Chemin public (ex. /uploads/collection/…).
  url              String
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())

  @@index([collectionItemId, sortOrder])
}

// ============================================================================
//  PORTEFEUILLE CRÉDITS (dépôts Stripe → solde interne, achats marketplace)
// ============================================================================

enum WalletEntryType {
  TOP_UP
  PURCHASE
  REFUND
  SALE_PAYOUT
  WITHDRAWAL
  ADJUSTMENT
}

model WalletAccount {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String   @unique
  /// Crédits déposés via Stripe — utilisables pour acheter, non retirables.
  depositBalance Decimal  @default(0) @db.Decimal(10, 2)
  /// Gains de ventes marketplace — retirables (Stripe Connect, à venir).
  earnedBalance  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  entries        WalletLedgerEntry[]
}

model WalletLedgerEntry {
  id                      String          @id @default(cuid())
  wallet                  WalletAccount   @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  walletAccountId         String
  type                    WalletEntryType
  /// Montant crédité ou débité (positif = entrée, négatif = sortie).
  amount                  Decimal         @db.Decimal(10, 2)
  /// Frais plateforme prélevés sur le dépôt (ex. 5 %).
  feeAmount               Decimal         @default(0) @db.Decimal(10, 2)
  balanceAfter            Decimal         @db.Decimal(10, 2)
  saleId                  String?
  stripeCheckoutSessionId String?         @unique
  stripeTransferId        String?         @unique
  note                    String?
  createdAt               DateTime        @default(now())

  @@index([walletAccountId, createdAt])
}

model WishlistItem {
  id            String        @id @default(cuid())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  card          Card          @relation(fields: [cardId], references: [id])
  cardId        String
  variant       CardVariant   @relation(fields: [variantId], references: [id])
  variantId     String
  season        Season        @relation(fields: [seasonId], references: [id])
  seasonId      String
  condition     CardCondition @default(EXCELLENT)
  /// "first" | "unlimited" — édition recherchée (aligné collection / vente).
  editionPreset String        @default("unlimited")
  note          String?
  createdAt     DateTime      @default(now())

  @@unique([userId, variantId, condition, editionPreset])
  @@index([userId])
}

/// Appréciation publique d'une carte (distinct de la wishlist).
model CardLike {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId    String
  createdAt DateTime @default(now())

  @@unique([userId, cardId])
  @@index([cardId])
}

// ============================================================================
//  MARKETPLACE — ANNONCES  (Module 6, 7)
// ============================================================================

model Listing {
  id           String        @id @default(cuid())
  seller       User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId     String
  variant      CardVariant   @relation(fields: [variantId], references: [id])
  variantId    String
  type         ListingType
  status       ListingStatus @default(ACTIVE)
  price        Decimal?      @db.Decimal(10, 2) // prix indicatif (vente)
  condition    CardCondition @default(EXCELLENT)
  quantity     Int           @default(1)
  shippingMode ShippingMode  @default(STANDARD)
  description  String?

  // pour les annonces "WANT" (je recherche)
  budgetMax    Decimal?       @db.Decimal(10, 2)
  minCondition CardCondition?

  viewCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sales Sale[]
  marketplaceCartItems MarketplaceCartItem[]

  @@index([variantId])
  @@index([sellerId])
  @@index([status, type])
  @@index([variantId, status])
}

/// Panier marketplace — réservation temporaire d'une annonce (1 acheteur à la fois).
model MarketplaceCartItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String   @unique
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model MarketplaceCheckout {
  id                      String                    @id @default(cuid())
  checkoutNumber          String                    @unique
  buyerId                 String
  buyer                   User                      @relation(fields: [buyerId], references: [id])
  status                  MarketplaceCheckoutStatus @default(PENDING)
  subtotal                Decimal                   @db.Decimal(10, 2)
  total                   Decimal                   @db.Decimal(10, 2)
  stripeCheckoutSessionId String?                   @unique
  paidAt                  DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  lines                   MarketplaceCheckoutLine[]
  invoices                MarketplaceInvoice[]

  @@index([buyerId])
  @@index([status])
}

model MarketplaceCheckoutLine {
  id         String              @id @default(cuid())
  checkoutId String
  checkout   MarketplaceCheckout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  saleId     String              @unique
  sale       Sale                @relation(fields: [saleId], references: [id])
  cartItemId String?
  listingId  String
  sellerId   String
  cardName   String
  unitPrice  Decimal             @db.Decimal(10, 2)

  @@index([checkoutId])
  @@index([sellerId])
}

model MarketplaceInvoice {
  id                    String                      @id @default(cuid())
  checkoutId            String
  checkout              MarketplaceCheckout         @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  invoiceNumber         String                      @unique
  recipient             MarketplaceInvoiceRecipient
  userId                String
  user                  User                        @relation(fields: [userId], references: [id])
  sellerId              String?
  amount                Decimal                     @db.Decimal(10, 2)
  lineItems             Json
  stripePaymentIntentId String?
  createdAt             DateTime                    @default(now())
  emailedAt             DateTime?

  @@index([checkoutId])
  @@index([userId])
}

// ============================================================================
//  BOUTIQUE OFFICIELLE  (maquettes Boutique/Panier/Checkout/Commandes)
// ============================================================================

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  slug        String      @unique
  type        ProductType
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  description String?
  images      String[]
  releaseDate DateTime?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems      OrderItem[]
  cartItems       CartItem[]
  stockMovements  StockMovement[]
}

model CartItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  user        User        @relation(fields: [userId], references: [id])
  userId      String
  status      OrderStatus @default(PENDING)

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @default(0) @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  // Livraison : référence au carnet d'adresses, avec copie inline en fallback (immuabilité historique)
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])
  shippingAddressId String?
  shippingName      String?
  shippingLine1     String?
  shippingZip       String?
  shippingCity      String?
  shippingCountry   String?
  shippingMethod    String? // Relais, Colissimo, Chronopost…
  trackingNumber    String?

  items    OrderItem[]
  payment  Payment?
  shipment Shipment?
  disputes Dispute[]

  createdAt DateTime  @default(now())
  shippedAt DateTime?
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
}

model StockMovement {
  id          String            @id @default(cuid())
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  type        StockMovementType
  quantity    Int               // positif = entrée, négatif = sortie
  reason      String?
  reference   String?           // orderId ou autre référence externe
  performedBy String?           // displayName ou userId de l'admin
  stockBefore Int
  stockAfter  Int
  createdAt   DateTime          @default(now())

  @@index([productId, createdAt])
}

// ============================================================================
//  ENCHÈRES  (maquette Encheres — temps réel, anti-snipe)
// ============================================================================

model Auction {
  id           String        @id @default(cuid())
  seller       User          @relation("AuctionSeller", fields: [sellerId], references: [id])
  sellerId     String
  variant      CardVariant   @relation(fields: [variantId], references: [id])
  variantId    String
  condition    CardCondition @default(EXCELLENT)
  startPrice   Decimal       @db.Decimal(10, 2)
  reservePrice Decimal?      @db.Decimal(10, 2)
  currentPrice Decimal       @default(0) @db.Decimal(10, 2)
  bidIncrement Decimal       @default(1) @db.Decimal(10, 2)
  status       AuctionStatus @default(SCHEDULED)
  antiSnipe    Boolean       @default(true)
  startsAt     DateTime
  endsAt       DateTime
  winner       User?         @relation("AuctionWinner", fields: [winnerId], references: [id])
  winnerId     String?

  bids         Bid[]
  payment      Payment?
  disputes     Dispute[]
  conversation Conversation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, endsAt])
}

model Bid {
  id        String   @id @default(cuid())
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  auctionId String
  bidder    User     @relation(fields: [bidderId], references: [id])
  bidderId  String
  amount    Decimal  @db.Decimal(10, 2)
  maxAmount Decimal? @db.Decimal(10, 2) // enchère automatique (proxy bidding)
  isAuto    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([auctionId])
}

// ============================================================================
//  ÉCHANGES ENTRE MEMBRES  (Module 8 — double validation)
// ============================================================================

model Exchange {
  id          String         @id @default(cuid())
  initiator   User           @relation("ExchangeInitiator", fields: [initiatorId], references: [id])
  initiatorId String
  recipient   User           @relation("ExchangeRecipient", fields: [recipientId], references: [id])
  recipientId String
  status      ExchangeStatus @default(PROPOSED)

  secured Boolean @default(false) // option envoi sécurisé
  message String?

  items        ExchangeItem[]
  shipments    Shipment[]
  payments     Payment[] // cautions (escrow) si sécurisé
  disputes     Dispute[]
  conversation Conversation?
  reviews      Review[]

  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([initiatorId])
  @@index([recipientId])
  @@index([status])
}

model ExchangeItem {
  id            String        @id @default(cuid())
  exchange      Exchange      @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  exchangeId    String
  /// true = côté initiateur, false = côté destinataire
  fromInitiator Boolean
  variant       CardVariant   @relation(fields: [variantId], references: [id])
  variantId     String
  condition     CardCondition @default(EXCELLENT)
  quantity      Int           @default(1)

  @@index([exchangeId])
}

// ============================================================================
//  VENTES MARKETPLACE (achat sécurisé)
// ============================================================================

model Sale {
  id        String     @id @default(cuid())
  listing   Listing    @relation(fields: [listingId], references: [id])
  listingId String
  buyer     User       @relation("SaleBuyer", fields: [buyerId], references: [id])
  buyerId   String
  seller    User       @relation("SaleSeller", fields: [sellerId], references: [id])
  sellerId  String
  status    SaleStatus @default(PENDING_PAYMENT)

  price        Decimal      @db.Decimal(10, 2)
  serviceFee   Decimal      @default(0) @db.Decimal(10, 2)
  shippingMode ShippingMode @default(STANDARD)
  shippingCost Decimal      @default(0) @db.Decimal(10, 2)

  shipment     Shipment?
  payments     Payment[]
  disputes     Dispute[]
  conversation Conversation?
  reviews      Review[]
  checkoutLine MarketplaceCheckoutLine?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// ============================================================================
//  ENVOI SÉCURISÉ / ESCROW — preuves vidéo, suivi, garantie  (maquettes
//  Envoi Sécurisé / Déballage Sécurisé / Prolongation Garantie)
// ============================================================================

model Shipment {
  id      String       @id @default(cuid())
  type    ShipmentType
  secured Boolean      @default(false)

  // Rattachement polymorphe (une seule des trois est renseignée)
  sale       Sale?     @relation(fields: [saleId], references: [id])
  saleId     String?   @unique
  exchange   Exchange? @relation(fields: [exchangeId], references: [id])
  exchangeId String?
  order      Order?    @relation(fields: [orderId], references: [id])
  orderId    String?   @unique

  shipper     User   @relation("ShipmentShipper", fields: [shipperId], references: [id])
  shipperId   String
  recipient   User   @relation("ShipmentRecipient", fields: [recipientId], references: [id])
  recipientId String

  carrier        Carrier?
  trackingNumber String?
  status         ShipmentStatus @default(PENDING)
  dropToken      String? // jeton du jour (anti-fraude), valable 24h
  dropTokenDate  DateTime? // jour de validité du jeton

  // Délai de dépôt après acceptation (J+3) : annulation si non expédié
  notShipDeadline DateTime?

  // Garantie post-livraison (fenêtre 72h, prolongeable 2x ; ré-auth J+5)
  guaranteeStartedAt DateTime?
  guaranteeEndsAt    DateTime?
  guaranteeExtended  Int       @default(0)
  reauthCount        Int       @default(0)
  lastReauthAt       DateTime?

  proofs         ShipmentProof[]
  payments       Payment[] // caution liée à cet envoi
  trackingEvents TrackingEvent[]

  createdAt   DateTime  @default(now())
  shippedAt   DateTime?
  deliveredAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([exchangeId])
  @@index([status])
}

/// Historique des statuts remontés par l'agrégateur transporteurs (suivi colis).
model TrackingEvent {
  id         String         @id @default(cuid())
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId String
  status     ShipmentStatus
  label      String? // libellé transporteur brut
  location   String?
  occurredAt DateTime // horodatage transporteur
  createdAt  DateTime       @default(now())

  @@index([shipmentId])
}

/// Journal horodaté (serveur) des transitions d'état d'une transaction.
/// Polymorphe (sale/exchange/order/shipment) : preuve d'historique pour litige (CDC).
model TransactionEvent {
  id         String   @id @default(cuid())
  entityType String // SALE, EXCHANGE, ORDER, SHIPMENT
  entityId   String
  fromStatus String?
  toStatus   String
  event      String // libellé de la transition / déclencheur
  actor      User?    @relation(fields: [actorId], references: [id])
  actorId    String? // null = transition système (timeout, webhook)
  metadata   Json?
  createdAt  DateTime @default(now()) // horodatage serveur

  @@index([entityType, entityId])
}

model ShipmentProof {
  id               String    @id @default(cuid())
  shipment         Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId       String
  kind             ProofKind
  mediaUrl         String
  storageKey       String? // clé de stockage objet (URL signée générée à la demande)
  mediaHash        String? // intégrité SHA-256 de la vidéo
  tokenShown       String? // jeton affiché à l'écran lors de la prise
  durationSec      Int? // durée de la vidéo continue
  recordedAt       DateTime  @default(now()) // horodatage client (indicatif)
  serverRecordedAt DateTime  @default(now()) // horodatage serveur (fait foi)

  // Purge RGPD : 60 j après clôture, 1 an si litige
  purgeScheduledAt DateTime?
  purgedAt         DateTime?
  retentionReason  String? // ex: "DISPUTE_OPEN"

  @@index([shipmentId])
  @@index([purgeScheduledAt])
}

// ============================================================================
//  PAIEMENTS / ESCROW STRIPE
// ============================================================================

model Payment {
  id                    String        @id @default(cuid())
  /// Payeur (acheteur / déposant de caution).
  user                  User          @relation("PaymentPayer", fields: [userId], references: [id])
  userId                String
  /// Bénéficiaire (vendeur, via Stripe Connect) — null pour une caution restituée.
  payee                 User?         @relation("PaymentPayee", fields: [payeeId], references: [id])
  payeeId               String?
  kind                  PaymentKind
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  amount                Decimal       @db.Decimal(10, 2)
  capturedAmount        Decimal       @default(0) @db.Decimal(10, 2)
  applicationFee        Decimal       @default(0) @db.Decimal(10, 2)
  currency              String        @default("EUR")
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  stripeTransferId      String? // virement Connect vers le vendeur
  reauthCount           Int           @default(0)

  // Rattachements (selon le flux)
  sale       Sale?     @relation(fields: [saleId], references: [id])
  saleId     String?
  exchange   Exchange? @relation(fields: [exchangeId], references: [id])
  exchangeId String?
  order      Order?    @relation(fields: [orderId], references: [id])
  orderId    String?   @unique
  auction    Auction?  @relation(fields: [auctionId], references: [id])
  auctionId  String?   @unique
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])
  shipmentId String?

  expiresAt  DateTime? // expiration de la pré-autorisation (~7j)
  capturedAt DateTime?
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([payeeId])
  @@index([status])
}

// ============================================================================
//  LITIGES & ARBITRAGE  (maquette Litige Arbitrage — Module 10)
// ============================================================================

model Dispute {
  id            String        @id @default(cuid())
  type          DisputeType
  status        DisputeStatus @default(OPEN)
  reason        String
  priority      Int           @default(0)
  involvesMinor Boolean       @default(false)

  claimant     User    @relation("DisputeClaimant", fields: [claimantId], references: [id])
  claimantId   String
  respondent   User    @relation("DisputeRespondent", fields: [respondentId], references: [id])
  respondentId String
  openedBy     User?   @relation("DisputeOpener", fields: [openedById], references: [id])
  openedById   String?

  // Rattachements (selon le type)
  sale       Sale?     @relation(fields: [saleId], references: [id])
  saleId     String?
  exchange   Exchange? @relation(fields: [exchangeId], references: [id])
  exchangeId String?
  order      Order?    @relation(fields: [orderId], references: [id])
  orderId    String?
  auction    Auction?  @relation(fields: [auctionId], references: [id])
  auctionId  String?

  // SLA de traitement modération (48h) + escalade
  dueAt           DateTime?
  escalationLevel Int       @default(0)

  // Appel d'un litige déjà clôturé (P2)
  appealOf   Dispute? @relation("DisputeAppeal", fields: [appealOfId], references: [id])
  appealOfId String?  @unique
  appeal     Dispute? @relation("DisputeAppeal")

  evidence     DisputeEvidence[]
  resolution   DisputeResolution?
  conversation Conversation?

  openedAt   DateTime  @default(now())
  resolvedAt DateTime?
  updatedAt  DateTime  @updatedAt

  @@index([status, priority])
  @@index([dueAt])
}

model DisputeEvidence {
  id         String   @id @default(cuid())
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  disputeId  String
  uploader   User     @relation(fields: [uploaderId], references: [id])
  uploaderId String
  kind       String // VIDEO_UNBOXING, PHOTO, TRACKING_SCREENSHOT…
  mediaUrl   String
  storageKey String?
  mediaHash  String?
  createdAt  DateTime @default(now())

  // Purge RGPD (1 an si litige)
  purgeScheduledAt DateTime?
  purgedAt         DateTime?
  retentionReason  String?

  @@index([disputeId])
  @@index([purgeScheduledAt])
}

model DisputeResolution {
  id              String          @id @default(cuid())
  dispute         Dispute         @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  disputeId       String          @unique
  moderator       User            @relation(fields: [moderatorId], references: [id])
  moderatorId     String
  verdict         DisputeVerdict
  captureDecision CaptureDecision @default(NONE)
  captureAmount   Decimal         @default(0) @db.Decimal(10, 2)
  notes           String?
  sanctions       Json?
  createdAt       DateTime        @default(now())
}

// ============================================================================
//  AVIS, RÉPUTATION, BADGES  (Module 8, 9)
// ============================================================================

model Review {
  id         String       @id @default(cuid())
  author     User         @relation("ReviewAuthor", fields: [authorId], references: [id])
  authorId   String
  target     User         @relation("ReviewTarget", fields: [targetId], references: [id])
  targetId   String
  source     ReviewSource
  sale       Sale?        @relation(fields: [saleId], references: [id])
  saleId     String?
  exchange   Exchange?    @relation(fields: [exchangeId], references: [id])
  exchangeId String?
  rating     Int // 1..5
  comment    String?
  visibility Visibility   @default(PUBLIC)
  createdAt  DateTime     @default(now())

  @@unique([authorId, saleId])
  @@unique([authorId, exchangeId])
  @@index([targetId])
}

model Badge {
  id          String      @id @default(cuid())
  code        String      @unique
  label       String
  description String?
  icon        String?
  users       UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  badgeId    String
  progress   Int      @default(100) // %
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

// ============================================================================
//  MESSAGERIE CONTEXTUALISÉE  (Module 8 — pas de messagerie privée libre)
// ============================================================================

model Conversation {
  id      String              @id @default(cuid())
  context ConversationContext

  // Une conversation est toujours liée à un contexte (1:1)
  exchange   Exchange? @relation(fields: [exchangeId], references: [id])
  exchangeId String?   @unique
  sale       Sale?     @relation(fields: [saleId], references: [id])
  saleId     String?   @unique
  auction    Auction?  @relation(fields: [auctionId], references: [id])
  auctionId  String?   @unique
  dispute    Dispute?  @relation(fields: [disputeId], references: [id])
  disputeId  String?   @unique

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User         @relation(fields: [senderId], references: [id])
  senderId       String
  body           String
  attachments    String[]
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// ============================================================================
//  NOTIFICATIONS  (transverse)
// ============================================================================

model Notification {
  id         String           @id @default(cuid())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       NotificationType
  actorId    String? // déclencheur (sans contrainte FK : polymorphe)
  entityType String?
  entityId   String?
  payload    Json?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
}

// ============================================================================
//  MODÉRATION & CONFORMITÉ (Module 10, LCEN)
// ============================================================================

model Report {
  id            String           @id @default(cuid())
  reporter      User             @relation(fields: [reporterId], references: [id])
  reporterId    String
  targetType    ReportTargetType
  targetId      String
  reason        String
  involvesMinor Boolean          @default(false)
  status        ReportStatus     @default(PENDING)
  priority      Int              @default(0)
  createdAt     DateTime         @default(now())

  @@index([status, priority])
}

model ModerationAction {
  id           String   @id @default(cuid())
  moderator    User     @relation(fields: [moderatorId], references: [id])
  moderatorId  String
  action       String // USER_SUSPENDED, LISTING_REMOVED, DISPUTE_ARBITRATED…
  targetType   String
  targetId     String
  targetUserId String? // utilisateur visé (filtrage rapide de l'audit)
  details      Json?
  createdAt    DateTime @default(now())

  @@index([moderatorId])
  @@index([targetUserId])
}

/// Journaux de connexion (obligation hébergeur LCEN, CDC §5.3).
model ConnectionLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  ip        String?
  userAgent String?
  action    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
//  RÉGLAGES PLATEFORME  (singleton — frais port, drop, mode démo)
// ============================================================================

model PlatformConfig {
  id                   String   @id @default("default")
  shopFreeShippingMin  Decimal  @default(50) @db.Decimal(10, 2)
  shopStandardShipping Decimal  @default(4.90) @db.Decimal(10, 2)
  shopDefaultCarrier   String   @default("Colissimo")
  /// Slug utilisateur démo si navigation sans login (null = désactivé)
  demoUserSlug         String?
  listingDefaultDays   Int      @default(30)
  updatedAt            DateTime @updatedAt
}
