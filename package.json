{
  "name": "the-park",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma migrate deploy && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "cards:optimize-images": "node scripts/optimize-card-images.mjs",
    "auth0:roles": "tsx scripts/setup-auth0-roles.ts",
    "auth0:setup": "tsx scripts/setup-auth0-triggers.ts",
    "auth0:disable-google": "tsx scripts/disable-auth0-google.ts",
    "staff:seed": "tsx scripts/seed-staff-accounts.ts",
    "test:resend": "tsx scripts/test-resend.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.22.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "next": "15.5.19",
    "next-intl": "^4.13.0",
    "pg": "^8.21.0",
    "pusher-js": "^8.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "stripe": "^18.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
